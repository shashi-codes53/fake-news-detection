{
  "manifest_version": 3,
  "name": "Fake News Detector",
  "version": "1.0",
  "description": "AI-powered fake news detection using BERT + TF-IDF. Flags article credibility in real time.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
  "http://localhost:5000/*",
  "https://fake-news-detection-rrs0.onrender.com/*"
],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png"
  }
}
